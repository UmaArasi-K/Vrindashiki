# Copy this file to .env and fill in your values before running locally.
# In Cloud Run, set these via --set-env-vars or Secret Manager.

# Server port (Cloud Run injects 8080 automatically)
PORT=8080

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Allowed CORS origins (comma-separated). In production this should be your Cloud Run URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Node environment
NODE_ENV=development

# (Future) Firebase / Firestore credentials
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# FIRESTORE_PROJECT_ID=your-gcp-project-id
